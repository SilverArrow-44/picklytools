# Cloudflare Pages headers — security + performance
# (Cloudflare reads this file automatically; no config needed)

/*
  # Security headers
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  # HTML always revalidates — deploys visible instantly, no stale pages.
  # Static assets below override this with long cache times.
  Cache-Control: no-cache

# Cache static assets aggressively (they rarely change)
/favicon.svg
  Cache-Control: public, max-age=604800

/icon-192.png
  Cache-Control: public, max-age=2592000

/icon-512.png
  Cache-Control: public, max-age=2592000

/og-image.png
  Cache-Control: public, max-age=2592000

/page.css
  Cache-Control: public, max-age=86400

/manifest.webmanifest
  Cache-Control: public, max-age=86400


/og/*
  Cache-Control: public, max-age=2592000
